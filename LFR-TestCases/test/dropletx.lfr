// Droplet-based assay: mix the three inputs through a mixer, then split the
// mixed stream to two outputs (result and waste).
module dropletx(
    finput analyte, reagent1, reagent2,
    foutput result, waste
);

    flow mixed;

    #MAP "MIXER" "~"
    assign mixed = ~(analyte + reagent1 + reagent2);

    assign result = mixed;
    assign waste = mixed;

endmodule
