// Mix inputs, then incubate and route to result.
module expresstest(finput plasmid, cell_suspension, foutput result);

    flow reaction_mix;
    storage incubator;

    assign reaction_mix = plasmid + cell_suspension;

    #MAP "INCUBATOR" "&"
    assign incubator = &reaction_mix;
    assign result = incubator;

endmodule
