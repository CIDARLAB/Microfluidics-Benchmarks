// Ring-style recirculation: mix inputs with feedback, abstract "process" as delay/mixer map.
module ring(
    finput input, input2, input3,
    foutput output
);

    flow temp1, temp2, temp3;

    assign temp1 = input + input2 + temp3;

    #MAP "MIXER" "~"
    assign temp2 = ~temp1;

    assign temp3 = temp2 + input3;

    assign output = temp3;

endmodule
