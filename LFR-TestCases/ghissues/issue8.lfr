// Same gradient-style numeric mixing as gradient.lfr; avoid nested fluid−fluid `-`
// inside one bracket expression (parser/eval order).
module issue8(
    finput P, Q, R,
    foutput [0:8] out
);
    assign out[0] = P;
    assign out[1] = (1.0/9.0)*(6.0*P + 3.0*Q);
    assign out[2] = (1.0/36.0)*(15.0*P + 18.0*Q + R);
endmodule
