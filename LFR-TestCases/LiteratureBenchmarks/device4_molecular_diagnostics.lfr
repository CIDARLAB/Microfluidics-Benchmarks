module device4_molecular_diagnostics(
    finput p1, p2,
    foutput p3, p4, p5
);

    storage biosensor_a, biosensor_b, outlet_hub;

    assign biosensor_a = p1 + p2;
    assign biosensor_b = p1 + p2;

    assign outlet_hub = biosensor_b;
    assign p3 = biosensor_a;
    assign p4 = outlet_hub;
    assign p5 = outlet_hub;

endmodule
